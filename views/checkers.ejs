<!DOCTYPE html>
<html lang="en">
<%- include("./partials/head.ejs") %>
<body>
        <header><%- include("./partials/navbar.ejs") %></header>
        <main>
            <aside class="left pane">

            </aside>
            <div class="gameArea">
                <%- include("./partials/form.ejs") %>
                <canvas id="board"></canvas>
            </div>
            <aside class="right pane"></aside>
       </main>
       <script>
        const ws = new WebSocket(`ws://${window.location.host}`);

        const form = document.querySelector(".room-form");
        const roomCodeInput = document.getElementById("roomCode");
        const displayNameInput = document.getElementById("displayName");
        const submitButton = document.querySelector(".room-form button")
        
        const lastCode = localStorage.getItem("recentRoomCode");
        const lastName = localStorage.getItem("displayName");

        if (lastCode !== null) roomCodeInput.value = lastCode;
        if (lastName !== null) displayNameInput.value = lastName;

        let room = null;
        let isMyTurn = false;
        let onlineID = null;
        
        form.addEventListener("submit", (e) => {
            e.preventDefault();
            localStorage.setItem("recentRoomCode", form["roomCode"].value);
            localStorage.setItem("displayName", form["displayName"].value);
            
            connectToRoom(
                form["roomCode"].value,
                form["displayName"].value,
            );
        });
        
        let board = Array(100).fill("");
        let currentPlayer = "b";
        let isWon = false;
        let lastSelectedIndex = null;
        for (let i = 0; i < 40; i++) {
            if ((i + Math.floor(i / 10)) % 2 == 0) {
                board[i] = "r";
                board[99 - i] = "b";
            }
        }
        const states = {
            PIECE_PICK: 0,
            MOVE_PICK: 1,
        };
        let currentState = states.PIECE_PICK;

        const canvas = document.getElementById("board");
        const context = canvas.getContext("2d");
        const checkerRadius = 25;
        canvas.width = 720;
        canvas.height = 720;


        function drawPossibleMoveCircle(x, y) {
            context.beginPath();
            context.arc(x * (canvas.width / 10) + (canvas.width / 20), (canvas.height / 10) * y + (canvas.height / 20), checkerRadius * 0.5, 0, 2 * Math.PI);
            context.fillStyle = "#cccccc55"
            context.fill();
            context.closePath();
        }

        function drawChecker(x, y, type) {
            context.beginPath();
            context.arc(x * (canvas.width / 10) + (canvas.width / 20), (canvas.height / 10) * y + (canvas.height / 20), checkerRadius, 0, 2 * Math.PI);
            context.fillStyle = type.startsWith("r") ? "red" : "black";
            context.fill();
            context.strokeStyle = type.startsWith("b") ? "#aaa" : "black";
            context.stroke();
            context.closePath();

            context.beginPath();
            context.arc(x * (canvas.width / 10) + (canvas.width / 20), (canvas.height / 10) * y + (canvas.height / 20), checkerRadius * 0.8, 0, 2 * Math.PI);
            context.strokeStyle = type.startsWith("b") ? "#aaa" : "black";
            context.stroke();
            context.closePath();

            context.beginPath();
            context.arc(x * (canvas.width / 10) + (canvas.width / 20), (canvas.height / 10) * y + (canvas.height / 20), checkerRadius * 0.4, 0, 2 * Math.PI);
            context.strokeStyle = type.startsWith("b") ? "#aaa" : "black";
            if (type.endsWith("k")) {
                context.fillStyle = "purple";
                context.fill();
            } 
            context.stroke();
            context.closePath();
        }

        function drawBoard() {
            for (let i = 0; i < 10; i++) {
                for (let j = 0; j < 10; j++) {
                    const index = j * 10 + i;
                    context.beginPath();
                    if (board[index].includes("h")) {
                        context.fillStyle = "yellow"
                    } else {
                        context.fillStyle = (index + j) % 2 === 0 ? "green" : "white"; 
                    }
                    context.fillRect((canvas.width / 10) * i, (canvas.height / 10) * j, (canvas.width / 10), (canvas.height / 10));
                    context.closePath();

                    if (board[index] !== "") {
                        drawChecker(i, j, board[index]);
                    }
                }
            }
        }

        function getIndex(x, y) {
            return y * 10 + x;
        }

        function hasChopAvailable(playerSign, position, direction) {
            for (let x = 0; x < 10; x++) {
                for (let y = 0; y < 10; y++) {
                    if (position !== null && position !== undefined) {
                        x = position.x;
                        y = position.y;
                    }
                    if (!board[getIndex(x, y)].startsWith(playerSign)) {
                        if (position !== null && position !== undefined) return false;
                        continue;
                    }
                    if (!board[getIndex(x, y)].endsWith("k")) {
                        if (playerSign.startsWith("b")) {
                            if (x-2 >= 0 && y-2 >= 0) {
                                if (board[getIndex(x-1, y-1)].startsWith("r") && board[getIndex(x-2, y-2)] === "") {
                                    return true;
                                }
                            }

                            if (x+2 < 10 && y-2 >= 0) {
                                if (board[getIndex(x+1, y-1)].startsWith("r") && board[getIndex(x+2, y-2)] === "") {
                                    return true;
                                }
                            }

                            if (x-2 >= 0 && y+2 < 10) {
                                if (board[getIndex(x-1, y+1)].startsWith("r") && board[getIndex(x-2, y+2)] === "") {
                                    return true;
                                }
                            }

                            if (x+2 < 10 && y+2 < 10) {
                                if (board[getIndex(x+1, y+1)].startsWith("r") && board[getIndex(x+2, y+2)] === "") {
                                    return true;
                                }
                            }
                        }

                        if (playerSign.startsWith("r")) {
                            if (x-2 >= 0 && y+2 < 10) {
                                if (board[getIndex(x-1, y+1)].startsWith("b") && board[getIndex(x-2, y+2)] === "") {
                                    return true;
                                }
                            }

                            if (x+2 < 10 && y+2 < 10) {
                                if (board[getIndex(x+1, y+1)].startsWith("b") && board[getIndex(x+2, y+2)] === "") {
                                    return true;
                                }
                            }

                            if (x-2 >= 0 && y-2 >= 0) {
                                if (board[getIndex(x-1, y-1)].startsWith("b") && board[getIndex(x-2, y-2)] === "") {
                                    return true;
                                }
                            }

                            if (x+2 < 10 && y-2 >= 0) {
                                if (board[getIndex(x+1, y-1)].startsWith("b") && board[getIndex(x+2, y-2)] === "") {
                                    return true;
                                }
                            }
                        }
                    } else {
                        for (let i = 1; i < 10; i++) {
                            if (x-i-1 >= 0) {
                                if (y-i-1 >= 0) {
                                    if (board[getIndex(x-i, y-i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x-i-1, y-i-1)] == "") {
                                        if (direction !== null && direction !== undefined) {
                                            if (direction.x === -1 && direction.y === -1) return false;
                                        }
                                        return true;
                                    }
                                }
                                if (y+i+1 < 10) {
                                    if (board[getIndex(x-i, y+i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x-i-1, y+i+1)] == "") {
                                         if (direction !== null && direction !== undefined) {
                                            if (direction.x === -1 && direction.y === 1) return false;
                                        }
                                        return true;
                                    }
                                }
                            }
                            if (x+i+1 < 10) {
                                if (y-i-1 >= 0) {
                                    if (board[getIndex(x+i, y-i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x+i+1, y-i-1)] == "") {
                                         if (direction !== null && direction !== undefined) {
                                            if (direction.x === 1 && direction.y === -1) return false;
                                        }
                                        return true;
                                    }
                                }
                                if (y+i+1 < 10) {
                                    if (board[getIndex(x+i, y+i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x+i+1, y+i+1)] == "") {
                                         if (direction !== null && direction !== undefined) {
                                            if (direction.x === 1 && direction.y === 1) return false;
                                        }
                                        return true;
                                    }
                                }
                            }
                        }
                    }
                    if (position !== null && position !== undefined) return false;
                }
            }
            return false;
        } 

        let possibleMoves = [];

        canvas.addEventListener("click", (e) => {
            if (!isMyTurn && room != null) return;
            if (isWon) return;
            const x = Math.floor(Math.max(0, Math.min(e.offsetX, canvas.width)) / (canvas.width / 10));
            const y = Math.floor(Math.max(Math.min(e.offsetY, canvas.height), 0) / (canvas.height / 10));
            const index = getIndex(x, y);

            switch (currentState) {
                case states.MOVE_PICK: {
                    const chosenMove = possibleMoves.find((move, index) => move.x === x && move.y === y);
                    if (chosenMove === undefined) {
                    } else {
                        // move player
                        // perform capture
                        // if reached end king player

                        board[getIndex(x, y)] = board[lastSelectedIndex].replace("h", "");
                        board[lastSelectedIndex] = "";
                        possibleMoves = [];

                        // capture
                        if (chosenMove.opponentPieceLocation !== null) {
                            board[getIndex(chosenMove.opponentPieceLocation.x, chosenMove.opponentPieceLocation.y)] = "";
                        }

                        const prevX = lastSelectedIndex % 10;
                        const prevY = Math.floor(lastSelectedIndex / 10);

                        if (room != null) sendMove(chosenMove, lastSelectedIndex);
                        if (!hasChopAvailable(currentPlayer, {x: x, y: y}, {x: x - prevX > 0 ? -1 : 1, y: y - prevY > 0 ? -1 : 1}) || chosenMove.opponentPieceLocation === null) {
                            if ((currentPlayer == "b" && y == 0) || (currentPlayer == "r" && y == 9)) {
                                board[getIndex(x, y)] = board[getIndex(x, y)] + "k";
                            }
                            isMyTurn = !isMyTurn;
                            currentPlayer = currentPlayer === "b" ? "r" : "b";
                        } 
                        if (room != null) updateState();
                        lastSelectedIndex = null;
                    }
                    currentState = states.PIECE_PICK;

                }
                case states.PIECE_PICK: {
                    let hasCapture = hasChopAvailable(currentPlayer.charAt(0));

                    if (board[index].startsWith(currentPlayer)) {
                        if (lastSelectedIndex !== null) {
                            board[lastSelectedIndex] = board[lastSelectedIndex].replace("h", "");
                            possibleMoves = [];
                        }
                        if (index === lastSelectedIndex) {
                            board[lastSelectedIndex] = board[lastSelectedIndex].replace("h", "");
                            lastSelectedIndex = null;
                            possibleMoves = [];           
                        } else {
                            board[index] =  board[index].slice(0, 1) + "h" + board[index].slice(1);
                            lastSelectedIndex = index;
                            
                            // any captures
                            // any free moves

                            if (board[index] == "bh") {
                                if (x - 2 >= 0 && y - 2 >= 0) {
                                    if (board[getIndex(x-1, y-1)].startsWith("r") && board[getIndex(x-2, y-2)] == "") {
                                        possibleMoves.push({x: x-2, y: y-2, opponentPieceLocation: {x: x-1, y:y-1}});
                                        hasCapture = true;
                                    }
                                }
                                if (x + 2 < 10 && y - 2 >= 0) {
                                    if (board[getIndex(x+1, y-1)].startsWith("r") && board[getIndex(x+2, y-2)] == "") {
                                        possibleMoves.push({x: x+2, y:y-2, opponentPieceLocation: {x: x+1, y:y-1}});
                                        hasCapture = true;
                                    }
                                }
                                if (x - 2 >= 0 && y + 2 < 10) {
                                    if (board[getIndex(x-1, y+1)].startsWith("r") && board[getIndex(x-2, y+2)] == "") {
                                        possibleMoves.push({x: x-2, y: y+2, opponentPieceLocation: {x: x-1, y: y+1}});
                                    }
                                }
                                if (x + 2 < 10 && y + 2 < 10) {
                                    if (board[getIndex(x+1, y+1)].startsWith("r") && board[getIndex(x+2, y+2)] == "") {
                                        possibleMoves.push({x: x+2, y:y+2, opponentPieceLocation: {x: x+1, y: y+1}});
                                    }
                                }
                                if (hasCapture == false) {
                                    if (x - 1 >= 0 && y - 1 >= 0) {
                                        if (board[getIndex(x-1, y-1)] === "") {
                                            possibleMoves.push({x: x-1, y: y-1, opponentPieceLocation: null});
                                        }
                                    }
                                    if (x+1 < 10 && y - 1 >= 0) {
                                        if (board[getIndex(x+1, y-1)] === "") {
                                            possibleMoves.push({x: x+1, y: y-1, opponentPieceLocation: null});
                                        }
                                    }
                                }
                            } else if (board[index] === "rh") {
                                if (x - 2 >= 0 && y + 2 < 10) {
                                    if (board[getIndex(x-1, y+1)].startsWith("b") && board[getIndex(x-2, y+2)] == "") {
                                        possibleMoves.push({x: x-2, y: y+2, opponentPieceLocation: {x: x-1, y: y+1}});
                                    }
                                }
                                if (x + 2 < 10 && y + 2 < 10) {
                                    if (board[getIndex(x+1, y+1)].startsWith("b") && board[getIndex(x+2, y+2)] == "") {
                                        possibleMoves.push({x: x+2, y:y+2, opponentPieceLocation: {x: x+1, y: y+1}});
                                    }
                                }
                                if (x - 2 >= 0 && y - 2 >= 0) {
                                    if (board[getIndex(x-1, y-1)].startsWith("b") && board[getIndex(x-2, y-2)] == "") {
                                        possibleMoves.push({x: x-2, y: y-2, opponentPieceLocation: {x: x-1, y:y-1}});
                                        hasCapture = true;
                                    }
                                }
                                if (x + 2 < 10 && y - 2 >= 0) {
                                    if (board[getIndex(x+1, y-1)].startsWith("b") && board[getIndex(x+2, y-2)] == "") {
                                        possibleMoves.push({x: x+2, y:y-2, opponentPieceLocation: {x: x+1, y:y-1}});
                                        hasCapture = true;
                                    }
                                }
                                if (hasCapture == false) {
                                    if (x - 1 >= 0 && y + 1 >= 0) {
                                        if (board[getIndex(x-1, y+1)] === "") {
                                            possibleMoves.push({x: x-1, y: y+1, opponentPieceLocation: null});
                                        }
                                    }
                                    if (x+1 < 10 && y + 1 >= 0) {
                                        if (board[getIndex(x+1, y+1)] === "") {
                                            possibleMoves.push({x: x+1, y: y+1, opponentPieceLocation: null});
                                        }
                                    }
                                }
                            } else if (board[index].endsWith("k")) {
                                const playerSign = board[index].charAt(0);
                                let directionalStop = {
                                    ul: false,
                                    ur: false,
                                    dl: false,
                                    dr: false,
                                };
                                if (hasCapture === true) {
                                    for (let i = 1; i < 10; i++) {
                                        if (x-i-1 >= 0) {
                                            if (y-i-1 >= 0) {
                                                if (board[getIndex(x-i, y-i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x-i-1, y-i-1)] == "" && !directionalStop.ul) {
                                                    let originalI = i;
                                                    while (i < 10 && x - i - 1 >= 0 && y - i - 1 >= 0) {
                                                        if (board[getIndex(x-i-1, y-i-1)] !== "") {
                                                            directionalStop.ul = true;
                                                            break;
                                                        };
                                                        possibleMoves.push({x: x - i - 1, y: y - i - 1, opponentPieceLocation: {x: x - originalI, y: y - originalI}});
                                                        i++;
                                                    }
                                                    i = originalI;
                                                    
                                                }
                                            }
                                            if (y+i+1 < 10) {
                                                if (board[getIndex(x-i, y+i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x-i-1, y+i+1)] == "" && !directionalStop.ur) {
                                                    let originalI = i;
                                                    while (i < 10 && x - i - 1 >= 0 && y + i + 1 < 10) {
                                                        if (board[getIndex(x-i-1, y+i+1)] !== "") {
                                                            directionalStop.ur = true;
                                                            break;
                                                        }
                                                        possibleMoves.push({x: x - i - 1, y: y + i + 1, opponentPieceLocation: {x: x - originalI, y: y + originalI}});
                                                        i++;
                                                    }
                                                    i = originalI;
                                                }
                                            }
                                        }
                                        if (x+i+1 < 10) {
                                            if (y-i-1 >= 0) {
                                                if (board[getIndex(x+i, y-i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x+i+1, y-i-1)] == "" && !directionalStop.dl) {
                                                    let originalI = i;
                                                    while (i < 10 && x + i + 1 < 10 && y - i - 1 >= 0) {
                                                        if (board[getIndex(x+i+1, y-i-1)] !== "") {
                                                            directionalStop.dl = true;
                                                            break;
                                                        }
                                                        possibleMoves.push({x: x + i + 1, y: y - i - 1, opponentPieceLocation: {x: x + originalI, y: y - originalI}});
                                                        i++;
                                                    }
                                                    i = originalI;
                                                }
                                            }
                                            if (y+i+1 < 10) {
                                                if (board[getIndex(x+i, y+i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x+i+1, y+i+1)] == "" && !directionalStop.dr) {
                                                    let originalI = i;
                                                    while (i < 10 && x + i + 1 < 10 && y + i + 1 < 10) {
                                                        if (board[getIndex(x+i+1, y+i+1)] !== "") {
                                                            directionalStop.dr = true;
                                                            break;
                                                        }
                                                        possibleMoves.push({x: x + i + 1, y: y + i + 1, opponentPieceLocation: {x: x + originalI, y: y + originalI}});
                                                        i++;
                                                    }
                                                    i = originalI;
                                                }
                                            }
                                        }
                                    }
    
                                } else {
                                    let i = 0;
                                    while (i < 10 && x - i - 1 >= 0 && y - i - 1 >= 0) {
                                        if (board[getIndex(x-i-1, y-i-1)] !== "") break;
                                        possibleMoves.push({x: x - i - 1, y: y - i - 1, opponentPieceLocation: null});
                                        i++;
                                    }
                                    i = 0;
                                    while (i < 10 && x - i - 1 >= 0 && y + i + 1 < 10) {
                                        if (board[getIndex(x-i-1, y+i+1)] !== "") break;
                                        possibleMoves.push({x: x - i - 1, y: y + i + 1, opponentPieceLocation: null});
                                        i++;
                                    }
                                    i = 0;
                                    while (i < 10 && x + i + 1 < 10 && y - i - 1 >= 0) {
                                        if (board[getIndex(x+i+1, y-i-1)] !== "") break;
                                        possibleMoves.push({x: x + i + 1, y: y - i - 1, opponentPieceLocation: null});
                                        i++;
                                    }
                                    i = 0;
                                    while (i < 10 && x + i + 1 < 10 && y + i + 1 < 10) {
                                        if (board[getIndex(x+i+1, y+i+1)] !== "") break;
                                        possibleMoves.push({x: x + i + 1, y: y + i + 1, opponentPieceLocation: null});
                                        i++;
                                    }
                                            
                                }
       
                            }
                            currentState = states.MOVE_PICK;
                        }
                    } else {
                        if (lastSelectedIndex !== null) {
                            board[lastSelectedIndex] = board[lastSelectedIndex].replace("h", "");
                        }
                        lastSelectedIndex = null;
                        hasCapture = false;
                        possibleMoves = [];
                    }
                    drawBoard();
                    for (let move of possibleMoves) {
                        drawPossibleMoveCircle(move.x, move.y);
                    }
                    break;
                }
            }
        });

        function sendMove(move, lastSelectedIndex) {
            ws.send(
                JSON.stringify({
                    event: "broadcastroom",
                    roomCode: room.roomCode,
                    body: {
                        event: "move",
                        move: {
                            ...move,
                            lastSelectedIndex
                        },
                    },
                }),
            );
        }

        function updateState() {
            ws.send(
                JSON.stringify({
                    event: "updatestate",
                    roomCode: room.roomCode,
                    gameState: {
                        board: board,
                        currentPlayer: currentPlayer,
                    }
                })
            )
        }

        function connectToRoom(roomCode, displayName) {
            fetch(`/numberinroom/${roomCode}`).then(async (res) => {
                const jsonData = await res.json();
                if (jsonData["event"] === "givenumberinroom") {
                    ws.send(
                        JSON.stringify({
                            event: "roomconnect",
                            roomCode: roomCode,
                            displayName: displayName,
                            gameName: "checkers",
                        }),
                    );
                } else {
                    ws.send(
                        JSON.stringify({
                            event: "roomconnect",
                            roomCode: roomCode,
                            displayName: displayName,
                            gameName: "checkers",
                            initialState: {
                                board: (() => {
                                    let board = Array(100).fill("");
                                    for (let i = 0; i < 40; i++) {
                                        if ((i + Math.floor(i / 10)) % 2 == 0) {
                                            board[i] = "r";
                                            board[99 - i] = "b";
                                        }
                                    }
                                    return board;
                                })(),
                                currentPlayer: "b",
                            },
                        }),
                    );
                }
            });
        }

        ws.addEventListener("open", () => {
            console.log("Connected to websocket");
            ws.addEventListener("message", (e) => {
                const data = JSON.parse(e.data);
                if (data["event"] == "roomconnected") {
                    console.log(
                        `Connected to room with room code ${data["roomCode"]}`,
                    );
                    board = data["gameState"].board;
                    room = {
                        roomCode: data["roomCode"],
                        numberOfPlayers: data["numberOfPlayers"],
                    };

                    if (room.numberOfPlayers === 1) {
                        isMyTurn = true;
                        currentPlayer = "b";
                    } else {
                        isMyTurn = false;
                    }
                    drawBoard();
                } else if (data["event"] == "roomnotconnected") {
                    console.log(
                        `Could not connect because ${data["reason"]}`,
                    );
                } else if (data["event"] == "move") {
                    const chosenMove = data["move"];
                    lastSelectedIndex = chosenMove.lastSelectedIndex;
                    console.log(chosenMove);
                    // move player
                    // perform capture
                    // if reached end king player

                    board[getIndex(chosenMove.x, chosenMove.y)] = board[lastSelectedIndex].replace("h", "");
                    board[lastSelectedIndex] = "";
                    possibleMoves = [];

                    // capture
                    if (chosenMove.opponentPieceLocation !== null) {
                        board[getIndex(chosenMove.opponentPieceLocation.x, chosenMove.opponentPieceLocation.y)] = "";
                    }

                    const prevX = lastSelectedIndex % 10;
                    const prevY = Math.floor(lastSelectedIndex / 10);

                    if (!hasChopAvailable(currentPlayer, {x: chosenMove.x, y: chosenMove.y}, {x: chosenMove.x - prevX > 0 ? -1 : 1, y: chosenMove.y - prevY > 0 ? -1 : 1}) || chosenMove.opponentPieceLocation === null) {
                        if ((currentPlayer == "b" && chosenMove.y == 0) || (currentPlayer == "r" && chosenMove.y == 9)) {
                            board[getIndex(chosenMove.x, chosenMove.y)] = board[getIndex(chosenMove.x, chosenMove.y)] + "k";
                        }
                        currentPlayer = currentPlayer === "b" ? "r" : "b";
                        isMyTurn = !isMyTurn;
                    } 
                    lastSelectedIndex = null;
                    currentState = states.PIECE_PICK;
                    drawBoard();

                    // if (isWon) return;
                    // const index = data["position"];
                    // const x = index % 3;
                    // const y = Math.floor(index / 3);

                    // if (board[index] === "") {
                    //     board[index] = currentPlayer;
                    //     drawBoard();
                    //     const result = checkGameWon(currentPlayer);

                    //     if (result.isWon === true) {
                    //         drawWinningLine(result.type);
                    //         isWon = true;
                    //     }
                    //     currentPlayer = currentPlayer === "x" ? "o" : "x";
                    //     isMyTurn = !isMyTurn;
                    // }
    
                }
            });
        });

        drawBoard();
