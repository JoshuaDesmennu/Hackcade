<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head.ejs") %>
</head>
<body>
    <header><%- include("./partials/navbar.ejs") %></header>
    <main>
        <button id="hideFormButton" class="form-shown">Hide Form</button>
        <div class="gameArea">
            <%- include("./partials/form.ejs") %>
            <canvas id="board"></canvas>
            <div class="game-info">
                <span id="isConnectedText" class="red">Not Connected</span>
                <span class="separator">.</span>
                <span id="faceOffText">You (black) vs (red) Local</span>
                <span class="separator">.</span>
                <span id="turnText" class="green">Black's Turn (You)</span>
            </div>
        </div>
        <div class="actionButtons">
            <button id="leaveButton">Leave Room</button>
            <button id="restartButton">Restart Game</button>
        </div>
    </main>

    <script>
    const protocol = location.protocol === "https:" ? "wss" : "ws";
    const ws = new WebSocket(`${protocol}://${location.host}`);

    const form = document.querySelector(".room-form");
    const roomCodeInput = document.getElementById("roomCode");
    const displayNameInput = document.getElementById("displayName");
    const submitButton = document.querySelector(".room-form button");
    const hideFormButton = document.getElementById("hideFormButton");
    const showNavbarActions = document.getElementById("navbarDropdownButton");
    const navbarLine = document.getElementById("navbarLine");
    const navbarActions = document.getElementById("navbarActions");
    const restartButton = document.getElementById("restartButton");
    const mediaQuery = window.matchMedia("(max-width: 760px)");

    const isConnectedText = document.getElementById("isConnectedText");
    const faceOffText = document.getElementById("faceOffText");
    const turnText = document.getElementById("turnText");
    const leaveButton = document.getElementById("leaveButton");

    const lastCode = localStorage.getItem("recentRoomCode");
    const lastName = localStorage.getItem("displayName");

    if (lastCode !== null) roomCodeInput.value = lastCode;
    if (lastName !== null) displayNameInput.value = lastName;

    let isRoomLeader = false;
    let isNavbarToggled = false;

    let room = null;
    let isMyTurn = false;
 
    let possibleMoves = [];
    let opponentLastMoves = [];
    
    let board = Array(100).fill("");
    let currentPlayer = "b";
    let isWon = false;
    let lastSelectedIndex = null;
    for (let i = 0; i < 40; i++) {
        if ((i + Math.floor(i / 10)) % 2 == 0) {
            board[i] = "r";
            board[99 - i] = "b";
        }
    }
    const states = {
        PIECE_PICK: 0,
        MOVE_PICK: 1,
    };
    let currentState = states.PIECE_PICK;
    let opponentNames = [];

    const canvas = document.getElementById("board");
    const context = canvas.getContext("2d");
    
    canvas.width = canvas.getBoundingClientRect().width;
    let previousWidth = canvas.width;
    canvas.height = canvas.width;
    let checkerRadius = 25 * (canvas.width / 720);
            
    // updates the dimension-related properties of the gameboard with new dimensions
    const updateBoardDimensions = () => {
        const newWidth = canvas.getBoundingClientRect().width;
        if (newWidth === previousWidth) return;

        // sync with animation redraw
        requestAnimationFrame(() => {
            previousWidth = newWidth;
            canvas.width = newWidth;
            canvas.height = newWidth;
            checkerRadius = 25 * (canvas.width / 720);
        })
    };

    // toggle navbar dropdown on or off
    showNavbarActions.addEventListener("click", () => {
        isNavbarToggled = !isNavbarToggled;
        if (isNavbarToggled) {
            navbarLine.className = "navbar-line";
            navbarActions.className = "navbar-actions"
            showNavbarActions.innerHTML = "&#x25B2;";
        } else {
            navbarLine.className = "navbar-line hidden";
            navbarActions.className = "navbar-actions hidden";
            showNavbarActions.innerHTML = "&#x25BC;";
        }
    });

    // leave room on click
    leaveButton.addEventListener('click', (e) => {
        leaveRoom();
    })

    // changes styles of navbar based on screen dimensions
    function handleMediaChange(e) {
        navbarLine.className = "navbar-line hidden";
        isNavbarToggled = false;
        if (e.matches) {
            showNavbarActions.innerHTML = "&#x25BC;";
            navbarActions.className = "navbar-actions hidden"
            showNavbarActions.className = "";
        } else {
            showNavbarActions.className = "hidden";
            navbarActions.className = "navbar-actions"
        }
    }
    mediaQuery.addEventListener("change", handleMediaChange);

    form.addEventListener("submit", (e) => {
        e.preventDefault();
        localStorage.setItem("recentRoomCode", form["roomCode"].value);
        localStorage.setItem("displayName", form["displayName"].value);
        
        connectToRoom(
            form["roomCode"].value,
            form["displayName"].value,
        );
    });

    hideFormButton.addEventListener("click", () => {
        if (form.classList.contains("hidden")) {
            form.classList.remove("hidden");
            hideFormButton.innerText = "Hide Form";
        } else {
            form.classList.add("hidden");
            hideFormButton.innerText = "Show Form";
        }
    });


    function drawPossibleMoveCircle(x, y) {
        context.beginPath();
        context.arc(x * (canvas.width / 10) + (canvas.width / 20), (canvas.height / 10) * y + (canvas.height / 20), checkerRadius * 0.5, 0, 2 * Math.PI);
        context.fillStyle = "#cccccc55"
        context.fill();
        context.closePath();
    }

    function drawChecker(x, y, type) {
        context.beginPath();
        context.arc(x * (canvas.width / 10) + (canvas.width / 20), (canvas.height / 10) * y + (canvas.height / 20), checkerRadius, 0, 2 * Math.PI);
        context.fillStyle = type.startsWith("r") ? "red" : "black";
        context.fill();
        context.strokeStyle = type.startsWith("b") ? "#aaa" : "black";
        context.stroke();
        context.closePath();

        context.beginPath();
        context.arc(x * (canvas.width / 10) + (canvas.width / 20), (canvas.height / 10) * y + (canvas.height / 20), checkerRadius * 0.8, 0, 2 * Math.PI);
        context.strokeStyle = type.startsWith("b") ? "#aaa" : "black";
        context.stroke();
        context.closePath();

        context.beginPath();
        context.arc(x * (canvas.width / 10) + (canvas.width / 20), (canvas.height / 10) * y + (canvas.height / 20), checkerRadius * 0.4, 0, 2 * Math.PI);
        context.strokeStyle = type.startsWith("b") ? "#aaa" : "black";
        if (type.endsWith("k")) {
            context.fillStyle = "purple";
            context.fill();
        } 
        context.stroke();
        context.closePath();
    }

    function drawBoard() {
        for (let i = 0; i < 10; i++) {
            for (let j = 0; j < 10; j++) {
                const index = j * 10 + i;
                context.beginPath();
                if (board[index].includes("h") || opponentLastMoves.filter((move) => move.x === i && move.y === j).length > 0) {
                    context.fillStyle = "yellow"
                } else {
                    context.fillStyle = (index + j) % 2 === 0 ? "green" : "white"; 
                }
                context.fillRect((canvas.width / 10) * i, (canvas.height / 10) * j, (canvas.width / 10), (canvas.height / 10));
                context.closePath();

                if (board[index] !== "") {
                    drawChecker(i, j, board[index]);
                }
            }
        }
    }

    function getIndex(x, y) {
        return y * 10 + x;
    }

    function hasChopAvailable(playerSign, position, direction) {
        for (let x = 0; x < 10; x++) {
            for (let y = 0; y < 10; y++) {
                if (position !== null && position !== undefined) {
                    x = position.x;
                    y = position.y;
                }
                if (!board[getIndex(x, y)].startsWith(playerSign)) {
                    if (position !== null && position !== undefined) return false;
                    continue;
                }
                if (!board[getIndex(x, y)].endsWith("k")) {
                    if (playerSign.startsWith("b")) {
                        if (x-2 >= 0 && y-2 >= 0) {
                            if (board[getIndex(x-1, y-1)].startsWith("r") && board[getIndex(x-2, y-2)] === "") {
                                return true;
                            }
                        }

                        if (x+2 < 10 && y-2 >= 0) {
                            if (board[getIndex(x+1, y-1)].startsWith("r") && board[getIndex(x+2, y-2)] === "") {
                                return true;
                            }
                        }

                        if (x-2 >= 0 && y+2 < 10) {
                            if (board[getIndex(x-1, y+1)].startsWith("r") && board[getIndex(x-2, y+2)] === "") {
                                return true;
                            }
                        }

                        if (x+2 < 10 && y+2 < 10) {
                            if (board[getIndex(x+1, y+1)].startsWith("r") && board[getIndex(x+2, y+2)] === "") {
                                return true;
                            }
                        }
                    }

                    if (playerSign.startsWith("r")) {
                        if (x-2 >= 0 && y+2 < 10) {
                            if (board[getIndex(x-1, y+1)].startsWith("b") && board[getIndex(x-2, y+2)] === "") {
                                return true;
                            }
                        }

                        if (x+2 < 10 && y+2 < 10) {
                            if (board[getIndex(x+1, y+1)].startsWith("b") && board[getIndex(x+2, y+2)] === "") {
                                return true;
                            }
                        }

                        if (x-2 >= 0 && y-2 >= 0) {
                            if (board[getIndex(x-1, y-1)].startsWith("b") && board[getIndex(x-2, y-2)] === "") {
                                return true;
                            }
                        }

                        if (x+2 < 10 && y-2 >= 0) {
                            if (board[getIndex(x+1, y-1)].startsWith("b") && board[getIndex(x+2, y-2)] === "") {
                                return true;
                            }
                        }
                    }
                } else {
                    for (let i = 1; i < 10; i++) {
                        if (x-i-1 >= 0) {
                            if (y-i-1 >= 0) {
                                if (board[getIndex(x-i, y-i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x-i-1, y-i-1)] == "") {
                                    if (direction !== null && direction !== undefined) {
                                        if (direction.x === -1 && direction.y === -1) return false;
                                    }
                                    return true;
                                }
                            }
                            if (y+i+1 < 10) {
                                if (board[getIndex(x-i, y+i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x-i-1, y+i+1)] == "") {
                                        if (direction !== null && direction !== undefined) {
                                        if (direction.x === -1 && direction.y === 1) return false;
                                    }
                                    return true;
                                }
                            }
                        }
                        if (x+i+1 < 10) {
                            if (y-i-1 >= 0) {
                                if (board[getIndex(x+i, y-i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x+i+1, y-i-1)] == "") {
                                        if (direction !== null && direction !== undefined) {
                                        if (direction.x === 1 && direction.y === -1) return false;
                                    }
                                    return true;
                                }
                            }
                            if (y+i+1 < 10) {
                                if (board[getIndex(x+i, y+i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x+i+1, y+i+1)] == "") {
                                        if (direction !== null && direction !== undefined) {
                                        if (direction.x === 1 && direction.y === 1) return false;
                                    }
                                    return true;
                                }
                            }
                        }
                    }
                }
                if (position !== null && position !== undefined) return false;
            }
        }
        return false;
    }

    canvas.addEventListener("click", (e) => {
        if (!isMyTurn && room != null) return;
        if (isWon) return;
        const x = Math.floor(Math.max(0, Math.min(e.offsetX, canvas.width)) / (canvas.width / 10));
        const y = Math.floor(Math.max(Math.min(e.offsetY, canvas.height), 0) / (canvas.height / 10));
        const index = getIndex(x, y);

        switch (currentState) {
            case states.MOVE_PICK: {
                const chosenMove = possibleMoves.find((move, index) => move.x === x && move.y === y);
                if (chosenMove != undefined) {
                    // move player
                    // perform capture
                    // if reached end king player

                    board[getIndex(x, y)] = board[lastSelectedIndex].replace("h", "");
                    board[lastSelectedIndex] = "";
                    possibleMoves = [];
                    opponentLastMoves = [];
                    // capture
                    if (chosenMove.opponentPieceLocation !== null) {
                        board[getIndex(chosenMove.opponentPieceLocation.x, chosenMove.opponentPieceLocation.y)] = "";
                    }

                    const prevX = lastSelectedIndex % 10;
                    const prevY = Math.floor(lastSelectedIndex / 10);

                    if (room != null) sendMove(chosenMove, lastSelectedIndex);
                    if (!hasChopAvailable(currentPlayer, {x: x, y: y}, {x: x - prevX > 0 ? -1 : 1, y: y - prevY > 0 ? -1 : 1}) || chosenMove.opponentPieceLocation === null) {
                        if ((currentPlayer == "b" && y == 0) || (currentPlayer == "r" && y == 9)) {
                            board[getIndex(x, y)] = board[getIndex(x, y)] + "k";
                        }
                        isMyTurn = !isMyTurn;
                        currentPlayer = currentPlayer === "b" ? "r" : "b";
                        turnText.innerText = `${currentPlayer == "b" ? "Black" : "Red"}'s Turn (${isMyTurn ? "You" : "Opponent"})`;
                        turnText.style.color = isMyTurn ? "green" : "white";
                    } 
                    if (room != null) updateState();
                    lastSelectedIndex = null;
                }
                currentState = states.PIECE_PICK;

            }
            case states.PIECE_PICK: {
                let hasCapture = hasChopAvailable(currentPlayer.charAt(0));

                if (board[index].startsWith(currentPlayer)) {
                    if (lastSelectedIndex !== null) {
                        board[lastSelectedIndex] = board[lastSelectedIndex].replace("h", "");
                        possibleMoves = [];
                    }
                    if (index === lastSelectedIndex) {
                        board[lastSelectedIndex] = board[lastSelectedIndex].replace("h", "");
                        lastSelectedIndex = null;
                        possibleMoves = [];           
                    } else {
                        board[index] =  board[index].slice(0, 1) + "h" + board[index].slice(1);
                        lastSelectedIndex = index;
                        
                        // any captures
                        // any free moves

                        if (board[index] == "bh") {
                            if (x - 2 >= 0 && y - 2 >= 0) {
                                if (board[getIndex(x-1, y-1)].startsWith("r") && board[getIndex(x-2, y-2)] == "") {
                                    possibleMoves.push({x: x-2, y: y-2, opponentPieceLocation: {x: x-1, y:y-1}});
                                    hasCapture = true;
                                }
                            }
                            if (x + 2 < 10 && y - 2 >= 0) {
                                if (board[getIndex(x+1, y-1)].startsWith("r") && board[getIndex(x+2, y-2)] == "") {
                                    possibleMoves.push({x: x+2, y:y-2, opponentPieceLocation: {x: x+1, y:y-1}});
                                    hasCapture = true;
                                }
                            }
                            if (x - 2 >= 0 && y + 2 < 10) {
                                if (board[getIndex(x-1, y+1)].startsWith("r") && board[getIndex(x-2, y+2)] == "") {
                                    possibleMoves.push({x: x-2, y: y+2, opponentPieceLocation: {x: x-1, y: y+1}});
                                }
                            }
                            if (x + 2 < 10 && y + 2 < 10) {
                                if (board[getIndex(x+1, y+1)].startsWith("r") && board[getIndex(x+2, y+2)] == "") {
                                    possibleMoves.push({x: x+2, y:y+2, opponentPieceLocation: {x: x+1, y: y+1}});
                                }
                            }
                            if (hasCapture == false) {
                                if (x - 1 >= 0 && y - 1 >= 0) {
                                    if (board[getIndex(x-1, y-1)] === "") {
                                        possibleMoves.push({x: x-1, y: y-1, opponentPieceLocation: null});
                                    }
                                }
                                if (x+1 < 10 && y - 1 >= 0) {
                                    if (board[getIndex(x+1, y-1)] === "") {
                                        possibleMoves.push({x: x+1, y: y-1, opponentPieceLocation: null});
                                    }
                                }
                            }
                        } else if (board[index] === "rh") {
                            if (x - 2 >= 0 && y + 2 < 10) {
                                if (board[getIndex(x-1, y+1)].startsWith("b") && board[getIndex(x-2, y+2)] == "") {
                                    possibleMoves.push({x: x-2, y: y+2, opponentPieceLocation: {x: x-1, y: y+1}});
                                }
                            }
                            if (x + 2 < 10 && y + 2 < 10) {
                                if (board[getIndex(x+1, y+1)].startsWith("b") && board[getIndex(x+2, y+2)] == "") {
                                    possibleMoves.push({x: x+2, y:y+2, opponentPieceLocation: {x: x+1, y: y+1}});
                                }
                            }
                            if (x - 2 >= 0 && y - 2 >= 0) {
                                if (board[getIndex(x-1, y-1)].startsWith("b") && board[getIndex(x-2, y-2)] == "") {
                                    possibleMoves.push({x: x-2, y: y-2, opponentPieceLocation: {x: x-1, y:y-1}});
                                    hasCapture = true;
                                }
                            }
                            if (x + 2 < 10 && y - 2 >= 0) {
                                if (board[getIndex(x+1, y-1)].startsWith("b") && board[getIndex(x+2, y-2)] == "") {
                                    possibleMoves.push({x: x+2, y:y-2, opponentPieceLocation: {x: x+1, y:y-1}});
                                    hasCapture = true;
                                }
                            }
                            if (hasCapture == false) {
                                if (x - 1 >= 0 && y + 1 >= 0) {
                                    if (board[getIndex(x-1, y+1)] === "") {
                                        possibleMoves.push({x: x-1, y: y+1, opponentPieceLocation: null});
                                    }
                                }
                                if (x+1 < 10 && y + 1 >= 0) {
                                    if (board[getIndex(x+1, y+1)] === "") {
                                        possibleMoves.push({x: x+1, y: y+1, opponentPieceLocation: null});
                                    }
                                }
                            }
                        } else if (board[index].endsWith("k")) {
                            const playerSign = board[index].charAt(0);
                            let directionalStop = {
                                ul: false,
                                ur: false,
                                dl: false,
                                dr: false,
                            };
                            if (hasCapture === true) {
                                for (let i = 1; i < 10; i++) {
                                    if (x-i-1 >= 0) {
                                        if (y-i-1 >= 0) {
                                            if (board[getIndex(x-i, y-i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x-i-1, y-i-1)] == "" && !directionalStop.ul) {
                                                let originalI = i;
                                                while (i < 10 && x - i - 1 >= 0 && y - i - 1 >= 0) {
                                                    if (board[getIndex(x-i-1, y-i-1)] !== "") {
                                                        directionalStop.ul = true;
                                                        break;
                                                    };
                                                    possibleMoves.push({x: x - i - 1, y: y - i - 1, opponentPieceLocation: {x: x - originalI, y: y - originalI}});
                                                    i++;
                                                }
                                                i = originalI;
                                                
                                            }
                                        }
                                        if (y+i+1 < 10) {
                                            if (board[getIndex(x-i, y+i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x-i-1, y+i+1)] == "" && !directionalStop.ur) {
                                                let originalI = i;
                                                while (i < 10 && x - i - 1 >= 0 && y + i + 1 < 10) {
                                                    if (board[getIndex(x-i-1, y+i+1)] !== "") {
                                                        directionalStop.ur = true;
                                                        break;
                                                    }
                                                    possibleMoves.push({x: x - i - 1, y: y + i + 1, opponentPieceLocation: {x: x - originalI, y: y + originalI}});
                                                    i++;
                                                }
                                                i = originalI;
                                            }
                                        }
                                    }
                                    if (x+i+1 < 10) {
                                        if (y-i-1 >= 0) {
                                            if (board[getIndex(x+i, y-i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x+i+1, y-i-1)] == "" && !directionalStop.dl) {
                                                let originalI = i;
                                                while (i < 10 && x + i + 1 < 10 && y - i - 1 >= 0) {
                                                    if (board[getIndex(x+i+1, y-i-1)] !== "") {
                                                        directionalStop.dl = true;
                                                        break;
                                                    }
                                                    possibleMoves.push({x: x + i + 1, y: y - i - 1, opponentPieceLocation: {x: x + originalI, y: y - originalI}});
                                                    i++;
                                                }
                                                i = originalI;
                                            }
                                        }
                                        if (y+i+1 < 10) {
                                            if (board[getIndex(x+i, y+i)].startsWith(playerSign === "b" ? "r" : "b") && board[getIndex(x+i+1, y+i+1)] == "" && !directionalStop.dr) {
                                                let originalI = i;
                                                while (i < 10 && x + i + 1 < 10 && y + i + 1 < 10) {
                                                    if (board[getIndex(x+i+1, y+i+1)] !== "") {
                                                        directionalStop.dr = true;
                                                        break;
                                                    }
                                                    possibleMoves.push({x: x + i + 1, y: y + i + 1, opponentPieceLocation: {x: x + originalI, y: y + originalI}});
                                                    i++;
                                                }
                                                i = originalI;
                                            }
                                        }
                                    }
                                }

                            } else {
                                let i = 0;
                                while (i < 10 && x - i - 1 >= 0 && y - i - 1 >= 0) {
                                    if (board[getIndex(x-i-1, y-i-1)] !== "") break;
                                    possibleMoves.push({x: x - i - 1, y: y - i - 1, opponentPieceLocation: null});
                                    i++;
                                }
                                i = 0;
                                while (i < 10 && x - i - 1 >= 0 && y + i + 1 < 10) {
                                    if (board[getIndex(x-i-1, y+i+1)] !== "") break;
                                    possibleMoves.push({x: x - i - 1, y: y + i + 1, opponentPieceLocation: null});
                                    i++;
                                }
                                i = 0;
                                while (i < 10 && x + i + 1 < 10 && y - i - 1 >= 0) {
                                    if (board[getIndex(x+i+1, y-i-1)] !== "") break;
                                    possibleMoves.push({x: x + i + 1, y: y - i - 1, opponentPieceLocation: null});
                                    i++;
                                }
                                i = 0;
                                while (i < 10 && x + i + 1 < 10 && y + i + 1 < 10) {
                                    if (board[getIndex(x+i+1, y+i+1)] !== "") break;
                                    possibleMoves.push({x: x + i + 1, y: y + i + 1, opponentPieceLocation: null});
                                    i++;
                                }
                                        
                            }
    
                        }
                        currentState = states.MOVE_PICK;
                    }
                } else {
                    if (lastSelectedIndex !== null) {
                        board[lastSelectedIndex] = board[lastSelectedIndex].replace("h", "");
                    }
                    lastSelectedIndex = null;
                    hasCapture = false;
                    possibleMoves = [];
                }
                drawBoard();
                for (let move of possibleMoves) {
                    drawPossibleMoveCircle(move.x, move.y);
                }
                break;
            }
        }
    });

    function sendMove(move, lastSelectedIndex) {
        ws.send(
            JSON.stringify({
                event: "broadcastroom",
                roomCode: room.roomCode,
                body: {
                    event: "move",
                    move: {
                        ...move,
                        lastSelectedIndex
                    },
                },
            }),
        );
    }

    function updateState() {
        ws.send(
            JSON.stringify({
                event: "updatestate",
                roomCode: room.roomCode,
                gameState: {
                    board: board,
                    currentPlayer: currentPlayer,
                    isWon: isWon,
                },
                isTurn: isMyTurn,
            })
        )
    }
    
    function createDefaultBoard() {
        let board = Array(100).fill("");
        for (let i = 0; i < 40; i++) {
            if ((i + Math.floor(i / 10)) % 2 == 0) {
                board[i] = "r";
                board[99 - i] = "b";
            }
        }
        return board;
    }

    function leaveRoom() {
        if (room == null) return;
            ws.send(
            JSON.stringify({
                event: "broadcastroom",
                roomCode: room.roomCode,
                body: {
                    event: "leaving",
                },
            }),
        );
        ws.send(
            JSON.stringify(
                {
                    event: "leaveroom",
                }
            )
        )
        isWon = false;
        room = null;
        isConnectedText.innerText = "Not Connected";
        isConnectedText.className = "red";
        faceOffText.innerText = "You (black) vs (red) Local";
        turnText.innerText = "Black's turn (You)"
        turnText.className = "green";
        currentPlayer = "b";
        isMyTurn = true;
        board = createDefaultBoard();
        opponentLastMoves = [];
        drawBoard();
    }

    function connectToRoom(roomCode, displayName) {
        room = null;
        isWon = false;

        fetch(`/numberinroom/${roomCode}`).then(async (res) => {
            const jsonData = await res.json();
            if (jsonData["event"] === "givenumberinroom") {
                ws.send(
                    JSON.stringify({
                        event: "roomconnect",
                        roomCode: roomCode,
                        displayName: displayName,
                        gameName: "checkers",
                    }),
                );
            } else {
                ws.send(
                    JSON.stringify({
                        event: "roomconnect",
                        roomCode: roomCode,
                        displayName: displayName,
                        gameName: "checkers",
                        initialState: {
                            board: createDefaultBoard(),
                            currentPlayer: "b",
                            isWon: false,
                        },
                    }),
                );
            }
        });
    }

    function restartGame() {
        if (!isRoomLeader && room != null) return;
        isWon = false;
        const mySign = isMyTurn ? currentPlayer : (currentPlayer === "b" ? "r" : "b");
        const myWord = mySign == "b" ? "Black" : "Red";
        turnText.innerText = `${myWord}'s Turn (You)`;
        turnText.style.color = "green";

        if (room != null) {
            faceOffText.innerText = `You (${myWord.toLowerCase()}) vs (${mySign == "r" ? "black" : "red"}) ${opponentNames[0] == null ? "Nobody" : opponentNames[0]}`;
        } else {
            faceOffText.innerText = "You (black) vs (red) Local"
        }

        currentPlayer = mySign;
        isMyTurn = isRoomLeader || (room == null);
        board = createDefaultBoard();
        opponentLastMoves = []

        if (room != null) {
            updateState();
            ws.send(JSON.stringify({
                event: "broadcastroom",
                roomCode: room.roomCode,
                body: {
                    event: "restart",
                }
            }))
        }

        drawBoard();
    }

    restartButton.addEventListener("click", () => {
        restartGame();
    })
    
    ws.addEventListener("open", () => {
        console.log("Connected to websocket");
        ws.addEventListener("message", (e) => {
            const data = JSON.parse(e.data);
            if (data["event"] == "roomconnected") {
                console.log(
                    `Connected to room with room code ${data["roomCode"]}`,
                );
                board = data["gameState"].board;
                room = {
                    roomCode: data["roomCode"],
                    numberOfPlayers: data["numberOfPlayers"],
                };

                currentPlayer = data["gameState"].currentPlayer;
                isRoomLeader = data["isRoomLeader"];
                isMyTurn = data["isTurn"];
                isConnectedText.innerText = "Connected";
                isConnectedText.className = "green";
                const mySign = isMyTurn ? currentPlayer : (currentPlayer === "b" ? "r" : "b");
                opponentNames = data["opponentNames"]
                faceOffText.innerText = `You (${mySign == "b" ? "black" : "red"}) vs (${mySign == "b" ? "red" : "black"}) ${opponentNames[0] == null ? "Nobody" : opponentNames[0]}`;
                turnText.innerText = `${currentPlayer == "b" ? "Black" : "Red"}'s Turn (${isMyTurn ? "You" : "Opponent"})`;
                turnText.style.color = isMyTurn ? "green" : "white";
                ws.send(JSON.stringify({
                    event: "broadcastroom",
                    roomCode: room.roomCode,
                    body: {
                        event: "justjoined",
                        displayName: localStorage.getItem("displayName"),
                    }
                }))
                // check winner here

                drawBoard();

                // if there is a winner (change false)
                if (false) {
                    // show winner
                    isWon = true;
                    turnText.innerText = `${(currentPlayer == "b" ? "Red" : "Black").toUpperCase()} Wins (${isMyTurn ? "Opponent" : "You"})`;
                    turnText.style.color = isMyTurn ? "white" : "gold";
                }
            } else if (data["event"] == "roomnotconnected") {
                alert(
                    `Could not connect because ${data["reason"]}`,
                );
            } else if (data["event"] == "move") {
                const chosenMove = data["move"];
                lastSelectedIndex = chosenMove.lastSelectedIndex;
                opponentLastMoves = [
                    {x: chosenMove.x, y: chosenMove.y},
                    {x: lastSelectedIndex % 10, y: Math.floor(lastSelectedIndex / 10)}
                ]
                // move player
                // perform capture
                // if reached end king player

                board[getIndex(chosenMove.x, chosenMove.y)] = board[lastSelectedIndex].replace("h", "");
                board[lastSelectedIndex] = "";
                possibleMoves = [];

                // capture
                if (chosenMove.opponentPieceLocation !== null) {
                    board[getIndex(chosenMove.opponentPieceLocation.x, chosenMove.opponentPieceLocation.y)] = "";
                }

                const prevX = lastSelectedIndex % 10;
                const prevY = Math.floor(lastSelectedIndex / 10);

                if (!hasChopAvailable(currentPlayer, {x: chosenMove.x, y: chosenMove.y}, {x: chosenMove.x - prevX > 0 ? -1 : 1, y: chosenMove.y - prevY > 0 ? -1 : 1}) || chosenMove.opponentPieceLocation === null) {
                    if ((currentPlayer == "b" && chosenMove.y == 0) || (currentPlayer == "r" && chosenMove.y == 9)) {
                        board[getIndex(chosenMove.x, chosenMove.y)] = board[getIndex(chosenMove.x, chosenMove.y)] + "k";
                    }
                    currentPlayer = currentPlayer === "b" ? "r" : "b";
                    isMyTurn = !isMyTurn;
                    turnText.innerText = `${currentPlayer == "b" ? "Black" : "Red"}'s Turn (${isMyTurn ? "You" : "Opponent"})`;
                    turnText.style.color = isMyTurn ? "green" : "white";
                } 
                lastSelectedIndex = null;
                currentState = states.PIECE_PICK;
                drawBoard();

            } else if (data["event"] == "justjoined") {
                // update the versus text and opponentNames
                const mySign = isMyTurn ? currentPlayer : (currentPlayer === "b" ? "r" : "b");
                faceOffText.innerText = `You (${mySign == "b" ? "black" : "red"}) vs (${mySign == "b" ? "red" : "black"}) ${data["displayName"]}`;
                opponentNames.push(data["displayName"]);
            } else if (data["event"] == "leaving") {
                const mySign = isMyTurn ? currentPlayer : (currentPlayer === "b" ? "r" : "b");
                faceOffText.innerText = `You (${mySign == "b" ? "black" : "red"}) vs (${mySign == "b" ? "red" : "black"}) Nobody`;
            } else if (data["event"] == "restart") {
                const otherSign = !isMyTurn ? currentPlayer : (currentPlayer === "b" ? "r" : "b");
                const otherWord = otherSign == "r" ? "Red" : "Black";
                isWon = false;
                turnText.innerText = `${otherWord}'s Turn (Opponent)`;
                turnText.style.color = "white";
                currentPlayer = otherSign;
                isMyTurn = isRoomLeader || (room == null);
                board = createDefaultBoard();
                opponentLastMoves = [];

                drawBoard();
            } else if (data["event"] == "leader") {
                isRoomLeader = true;
            } else if (data["event"] == "newopponentlist") {
                opponentNames = data["opponentNames"]
            }

        });
    });

    handleMediaChange(mediaQuery);
    drawBoard();
   </script>
</body>

</html>

